// Minimal tsconfig for running scripts locally via ts-node
// Usage: npx ts-node --project tsconfig.backfill.json scripts/backfill-embeddings.ts
{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2019",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": ".ts-node-out"
  },
  "include": ["scripts/**/*.ts"]
}
